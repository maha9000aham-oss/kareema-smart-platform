<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>منصة كريمة الذكية</title>

<style>
body {
  margin:0;
  font-family: Arial;
  background:#F5F4FB;
}

/* اختصار الشكل لتجنب التعليق */
.hidden{display:none}
</style>
</head>

<body>

<div id="app"></div>
<script>
const banks = {
  math: {
    name: "الرياضيات",
    questions: []
  }
};

/* نظام مرن */
function normalizeQuestion(q){
  return {
    q: q.q,
    choices: q.choices || [],
    answer: q.answer,
    note: q.note || "",
    media: q.media || {type:"none"}
  };
}

/* عرض */
function renderQuestion(q){
  const app = document.getElementById("app");

  app.innerHTML = `
    <h2>${q.q}</h2>
    ${q.choices.map(c => `<button onclick="check('${c}')">${c}</button>`).join("<br>")}
    <div id="feedback"></div>
  `;
}

/* تحقق */
let current = 0;

function check(choice){
  const q = banks.math.questions[current];
  const fb = document.getElementById("feedback");

  if(choice === q.answer){
    fb.innerHTML = "✅ صحيح<br>" + q.note;
  } else {
    fb.innerHTML = "❌ خطأ<br>" + q.note;
  }
}
  /* إضافة أسئلة بدون لخبطة */
function addQuestions(list){
  banks.math.questions.push(...list);
}

/* مثال سؤال */
addQuestions([
  {
    q: "كم ناتج 5 + 3 ؟",
    choices: ["6","7","8","9"],
    answer: "8",
    note: "5 + 3 = 8"
  }
]);

renderQuestion(banks.math.questions[0]);
</script>

</body>
</html>
